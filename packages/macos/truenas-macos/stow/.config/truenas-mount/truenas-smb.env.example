# Copy this file to:
#   ~/.config/truenas-mount/truenas-smb.env
# then set strict permissions:
#   chmod 600 ~/.config/truenas-mount/truenas-smb.env

# Hostname or IP of your TrueNAS box.
SMB_HOST="truenas.lan"

# Share segment only (do not include leading slashes).
SMB_SHARE="your-share-name"

# SMB account for the share.
SMB_USERNAME="your-username"
SMB_PASSWORD="your-password"
# If your password has special URL characters, set SMB_PASSWORD_URI instead
# (pre-encoded), and leave SMB_PASSWORD unused.
# SMB_PASSWORD_URI="your-percent-encoded-password"

# Local mountpoint directory.
SMB_MOUNTPOINT="${HOME}/mnt/truenas"

# Connection pre-check retries (port 445 reachability).
SMB_CONNECT_ATTEMPTS=4
SMB_CONNECT_SLEEP_SECONDS=5

# mount_smbfs retries after successful reachability check.
SMB_MOUNT_ATTEMPTS=3
SMB_MOUNT_SLEEP_SECONDS=4
