// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "buffer_font_weight": 600.0,
  "which_key": {
    "delay_ms": 300,
    "enabled": true,
  },
  "title_bar": {
    "show_branch_icon": true,
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "ui_font_family": "Hack Nerd Font",
  "buffer_font_family": "Hack Nerd Font Mono",
  "buffer_font_features": {
    "calt": true
  },
  "icon_theme": {
    "mode": "light",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": true,
  "current_line_highlight": "all",
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "off",
  "vertical_scroll_margin": 8,
  "tab_bar": {
    "show": true,
  },
  "tabs": {
    "activate_on_close": "history",
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_project_panel": false,
    "enable_preview_from_file_finder": true,
    "enable_preview_from_multibuffer": false,
    "enable_preview_multibuffer_from_code_navigation": false,
    "enable_preview_file_from_code_navigation": false,
    "enable_keep_preview_on_code_navigation": false,
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "diagnostics": "all",
  },
  "diagnostics": {
    "inline": {
      "enabled": false,
    },
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 300,
    },
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": false,
    "hide_hidden": true,
    "file_icons": true,
    "entry_spacing": "standard",
    "default_width": 220.0,
    "indent_size": 16.0,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "session": {
    "trust_all_worktrees": true,
    "restore_unsaved_buffers": true,
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 120,
  },
  "ui_font_size": 14,
  "buffer_font_size": 13.5,
  "buffer_line_height": {
    "custom": 1.15
  },
  "theme": {
    "mode": "light",
    "light": "Nord Light",
    "dark": "OneNord Blurred",
  },
  "terminal": {
    "font_family": "Hack Nerd Font Mono",
    "font_size": 13,
    "font_weight": 600,
    "line_height": {
      "custom": 1.15
    }
  },
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "!solargraph", "!rubocop", "..."],
    },
    // Enable herb and ruby-lsp for *.html.erb files
    "HTML+ERB": {
      "language_servers": ["herb", "ruby-lsp", "..."],
    },
    // Enable ruby-lsp for *.js.erb files
    "JS+ERB": {
      "language_servers": ["ruby-lsp", "..."],
    },
    // Enable ruby-lsp for *.yaml.erb files
    "YAML+ERB": {
      "language_servers": ["ruby-lsp", "..."],
    },
  },
}
