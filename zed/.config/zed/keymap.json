[
  {
    "context": "Dock",
    "bindings": {
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w j": "workspace::ActivatePaneDown",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w j": "workspace::ActivatePaneDown",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "space f f": "file_finder::Toggle",
      "space f w": "pane::DeploySearch",
      "space f b": "tab_switcher::Toggle",
      "space f h": "outline::Toggle",
      "space f s": "project_symbols::Toggle",
      "space e": "project_panel::ToggleFocus",
      "space shift-e": "pane::RevealInProjectPanel",
      "space q": "diagnostics::Deploy",
      "space g t": "git_panel::ToggleFocus",
      "space g d": "git::Diff",
      "space x": ["pane::CloseActiveItem", { "close_pinned": false }],
      "space b p": "pane::TogglePinTab",
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem"
    }
  }
]
